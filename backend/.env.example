# Spring datasource
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lidarpro
DB_USER=lidarpro
DB_PASSWORD=change-me

# Server
SERVER_PORT=8080

# CORS (comma-separated origins/patterns)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://*.ondigitalocean.app,capacitor://localhost,ionic://localhost

# Local storage (dev)
APP_STORAGE_PROVIDER=local
APP_STORAGE_ROOT_DIR=./data/models
APP_STORAGE_PUBLIC_BASE_URL=/api/scans

# Firebase Storage (set APP_STORAGE_PROVIDER=firebase to enable)
APP_STORAGE_FIREBASE_API_KEY=
APP_STORAGE_FIREBASE_AUTH_DOMAIN=
APP_STORAGE_FIREBASE_PROJECT_ID=
APP_STORAGE_FIREBASE_BUCKET=
APP_STORAGE_FIREBASE_MESSAGING_SENDER_ID=
APP_STORAGE_FIREBASE_APP_ID=

# Provide either a service-account JSON string/file, or rely on GOOGLE_APPLICATION_CREDENTIALS.
APP_STORAGE_FIREBASE_CREDENTIALS_JSON=
APP_STORAGE_FIREBASE_CREDENTIALS_BASE64=
APP_STORAGE_FIREBASE_CREDENTIALS_FILE=

# Auth / JWT
APP_AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
APP_AUTH_ACCESS_TOKEN_MINUTES=120
APP_AUTH_JWT_ISSUER=lidarpro-backend
APP_AUTH_JWT_AUDIENCE=lidarpro-mobile-app

# Optional: Supabase session pooler example
# DB_HOST=aws-0-<region>.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.<project-ref>
# DB_PASSWORD=your-supabase-db-password
